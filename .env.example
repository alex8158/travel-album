# =============================================================================
# Travel Album Site V2 — Environment Variable Example
# -----------------------------------------------------------------------------
# 用法：
#   1. 复制本文件为 `.env`（仓库根目录或 server/ 下均可，server 启动时
#      会优先加载 server/.env，再加载根目录 .env，先到先得）。
#   2. 按需调整下面的值；空值或未填写时由 server/src/config/index.ts
#      使用 zod 校验后填入默认值。
#   3. 不要把真实密钥提交到 git。`.gitignore` 已经忽略 `.env*`，仅保留
#      `.env.example`。
#
# 系统级依赖（不是 npm 包）：
#   - `ffmpeg` 与 `ffprobe` 必须由宿主机提供。
#       macOS:  `brew install ffmpeg`
#       Ubuntu: `sudo apt-get install ffmpeg`
#   - 缺失时视频任务以 `FFMPEG_NOT_AVAILABLE` 失败；图片处理流程不受影响。
#
# 运行规则参考：
#   - docs/requirements.md §8、§12
#   - docs/design.md §11.1（配置项分组）、§9（任务队列）、§7.7（封面策略）、§8.4（ffmpeg 启动检查）
#   - CLAUDE.md §5（不提交 .env）
# =============================================================================

# -----------------------------------------------------------------------------
# Runtime
#   NODE_ENV 为唯一无默认值的必填项；缺失或非法值会让服务在启动阶段直接报错。
# -----------------------------------------------------------------------------
NODE_ENV=development
PORT=3000

# -----------------------------------------------------------------------------
# Storage（design §5）
#   第一版只有 local 实现；s3 留作后续替换。STORAGE_LOCAL_ROOT 是相对工作目录
#   的相对路径，也可以写成绝对路径。
# -----------------------------------------------------------------------------
STORAGE_DRIVER=local
STORAGE_LOCAL_ROOT=./storage

# -----------------------------------------------------------------------------
# Database（design §4）
#   第一版使用 SQLite；DATABASE_PATH 是相对工作目录的文件路径。
# -----------------------------------------------------------------------------
DATABASE_PATH=./data/app.db

# -----------------------------------------------------------------------------
# Workers（design §1.2 / §9.2）
#   按任务类型独立通道：图片 / 视频 / AI。FFmpeg 子进程总数 ≤ VIDEO_WORKER_CONCURRENCY。
#   JOB_RETRY_MAX：handler 失败后的最大重试次数（不含首次尝试）。0 表示禁用重试。
#   JOB_RETRY_BASE_DELAY_MS / JOB_RETRY_MAX_DELAY_MS：指数退避 base 与上限。
#   ZOMBIE_TIMEOUT_MS：长时间停留在 running 状态的任务被识别为僵尸（毫秒）。
# -----------------------------------------------------------------------------
IMAGE_WORKER_CONCURRENCY=2
VIDEO_WORKER_CONCURRENCY=1
AI_WORKER_CONCURRENCY=1
JOB_RETRY_MAX=3
JOB_RETRY_BASE_DELAY_MS=1000
JOB_RETRY_MAX_DELAY_MS=60000
ZOMBIE_TIMEOUT_MS=1800000

# -----------------------------------------------------------------------------
# 外部二进制（design §8.4）
#   留空表示从 PATH 查找。手动指定优先级更高。
# -----------------------------------------------------------------------------
# FFMPEG_PATH=/usr/local/bin/ffmpeg
# FFPROBE_PATH=/usr/local/bin/ffprobe

# -----------------------------------------------------------------------------
# AI（design §7.6 / requirements §7.10）
#   AI_ENABLED=false 是默认；未启用时前端按钮置灰，基础流程不受影响。
#   AI_ENABLED=true 时 AI_PROVIDER 必填（zod 会校验）。
#   *_LIMIT=0 表示不限制；建议正式环境配上限。
# -----------------------------------------------------------------------------
AI_ENABLED=false
AI_PROVIDER=
AI_DAILY_LIMIT=0
AI_TRIP_LIMIT=0

# -----------------------------------------------------------------------------
# Upload（requirements §7.2 / §7.3）
#   UPLOAD_MAX_FILE_SIZE 单位字节；默认 500 MiB。
#   扩展名列表用逗号分隔，大小写不敏感（解析时统一转小写）。
# -----------------------------------------------------------------------------
UPLOAD_MAX_FILE_SIZE=524288000
UPLOAD_ALLOWED_IMAGE_EXT=jpg,jpeg,png,webp,heic
UPLOAD_ALLOWED_VIDEO_EXT=mp4,mov,m4v,avi,mkv

# -----------------------------------------------------------------------------
# Delete（design §4.3）
#   第一轮主流程仅做软删除 + 恢复；永久删除接口需要 PERMANENT_DELETE_ENABLED=true
#   才放开，且必须等 P7.T1–T6 全部通过。
# -----------------------------------------------------------------------------
PERMANENT_DELETE_ENABLED=false

# -----------------------------------------------------------------------------
# 图片质量阈值（design §11.1）
#   - BLUR_THRESHOLD_BLURRY < BLUR_THRESHOLD_MAYBE，越高表示越清晰（Laplacian variance）。
#   - PHASH_DISTANCE_MAX：感知 hash 海明距离 ≤ 该值视为相似。
#   - 四个 QUALITY_WEIGHT_* 之和应约等于 1（容差 0.05）。
# -----------------------------------------------------------------------------
BLUR_THRESHOLD_BLURRY=50
BLUR_THRESHOLD_MAYBE=120
PHASH_DISTANCE_MAX=8
QUALITY_WEIGHT_RESOLUTION=0.3
QUALITY_WEIGHT_SHARPNESS=0.4
QUALITY_WEIGHT_EXPOSURE=0.2
QUALITY_WEIGHT_COLOR=0.1

# -----------------------------------------------------------------------------
# 视频参数（design §8）
#   VIDEO_SEGMENT_DURATION：固定时长切片（秒），第一版兜底策略。
#   VIDEO_PROXY_HEIGHT：低清代理短边像素。
#   VIDEO_KEYFRAME_INTERVAL：抽帧间隔（秒）。
#   BLACK_DETECT_DURATION：FFmpeg blackdetect 的最小持续时长（秒）。
# -----------------------------------------------------------------------------
VIDEO_SEGMENT_DURATION=10
VIDEO_PROXY_HEIGHT=720
VIDEO_KEYFRAME_INTERVAL=2
BLACK_DETECT_DURATION=0.5

# -----------------------------------------------------------------------------
# P11.T1 视频基础优化（user-facing 浏览器友好再编码；design §8.3 / §11.1）
#   VIDEO_OPTIMIZE_TARGET_HEIGHT：输出短边像素上限；不放大低分辨率视频。
#   VIDEO_OPTIMIZE_CRF：libx264 CRF（0..51，越低越清晰）；23 = 视觉透明。
#   VIDEO_OPTIMIZE_PRESET：libx264 速度/压缩档位；medium = 默认。
#   VIDEO_OPTIMIZE_VIDEO_CODEC / VIDEO_OPTIMIZE_AUDIO_CODEC：H.264 + AAC。
#   VIDEO_OPTIMIZE_AUDIO_BITRATE_KBPS：AAC 码率；160 kbps = stereo 透明。
#   VIDEO_OPTIMIZE_TIMEOUT_MS：ffmpeg 子进程墙钟超时；10 分钟兜底。
#   VIDEO_OPTIMIZE_WORKER_VERSION：写入 media_versions.params 便于历史回溯。
# 说明：不做音频归一化 / 淡入淡出 / 配乐替换 / 多段合成（属 P11.T2~T9）。
# -----------------------------------------------------------------------------
VIDEO_OPTIMIZE_TARGET_HEIGHT=1080
VIDEO_OPTIMIZE_CRF=23
VIDEO_OPTIMIZE_PRESET=medium
VIDEO_OPTIMIZE_VIDEO_CODEC=libx264
VIDEO_OPTIMIZE_AUDIO_CODEC=aac
VIDEO_OPTIMIZE_AUDIO_BITRATE_KBPS=160
VIDEO_OPTIMIZE_TIMEOUT_MS=600000
VIDEO_OPTIMIZE_WORKER_VERSION=1.0
